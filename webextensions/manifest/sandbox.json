              },
              "edge": "mirror",
              "firefox": {
                "version_added": "154",
                "notes": "Only available in Manifest V2. From Manifest V3, use `content_security_policy.sandbox` instead."
              },
              "firefox_android": "mirror",
              "opera": "mirror",
              "safari": {
                "version_added": false
              },
              "safari_ios": "mirror"
            }
          }
        },
        "pages": {
          "__compat": {
            "support": {
              "chrome": {
                "version_added": "≤22"
              },
              "edge": "mirror",
              "firefox": {
                "version_added": "154"
              },
              "firefox_android": "mirror",
              "opera": "mirror",
              "safari": {
                "version_added": "15.4"
              },
              "safari_ios": "mirror"
            }
          }
        }
      }
    }
  }
}
