{
  "webextensions": {
    "manifest": {
      "sandbox": {
        "__compat": {
          "support": {
            "chrome": {
              "version_added": "≤22"
            },
            "edge": "mirror",
            "firefox": {
              "version_added": "154"
            },
            "firefox_android": "mirror",
            "opera": "mirror",
            "safari": {
              "version_added": "15.4"
            },
            "safari_ios": "mirror"
          }
        },
        "content_security_policy": {
          "__compat": {
            "support": {
