{
  "mediatypes": {
    "image": {
      "jxl": {
        "__compat": {
          "description": "JPEG XL",
          "tags": [
            "web-features:jpegxl"
          ],
          "support": {
            "chrome": {
              "version_added": "145",
              "flags": [
                {
                  "type": "preference",
                  "name": "#enable-jxl-image-format",
                  "value_to_set": "Enabled"
                }
              ],
              "notes": "Earlier flag support was added in Chrome 91 and removed in Chrome 110. See [bug 40168998](https://crbug.com/40168998#comment85)."
            },
            "chrome_android": "mirror",
            "edge": {
              "version_added": false,
              "notes": "Earlier flag support was added in Edge 91 and removed in Edge 110."
            },
            "firefox": {
              "version_added": "152",
              "flags": [
                {
                  "type": "preference",
                  "name": "image.jxl.enabled",
                  "value_to_set": "true"
                }
              ]
            },
            "firefox_android": "mirror",
            "opera": {
              "version_added": false,
              "notes": "Earlier flag support was added in Opera 77 and removed in Opera 96."
            },
            "opera_android": "mirror",
            "safari": {
              "version_added": "17",
              "notes": "Animated images are not supported."
            },
            "safari_ios": "mirror",
            "samsunginternet_android": "mirror",
            "webview_android": "mirror",
            "webview_ios": "mirror"
          },
          "status": {
            "experimental": false,
            "standard_track": false,
            "deprecated": false
          }
        }
      }
    }
  }
}
